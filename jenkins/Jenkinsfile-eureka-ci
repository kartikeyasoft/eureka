pipeline {
    agent any

    tools {
        maven 'Maven-3.8'
        jdk 'JDK-11'
    }

    environment {
        NEXUS_URL = 'http://your-nexus:8081/repository/maven-releases'
        NEXUS_CREDS = credentials('nexus-creds')
        SERVICE_NAME = 'eureka'
        AWS_ACCESS_KEY_ID     = credentials('aws-access-key-id')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
    }

    stages {
        stage('Checkout') {
            steps {
                git credentialsId: 'gitlab', url: 'https://github.com/kartikeyasoft/eureka.git', branch: 'main'
            }
        }

        stage('Debug Workspace') {
            steps {
                sh 'pwd'
                sh 'ls -la'
                sh 'echo "Maven home: ${MAVEN_HOME}"'
                sh 'mvn --version || echo "Maven not found"'
                sh 'java -version || echo "Java not found"'
                sh 'cat pom.xml | head -20 || echo "pom.xml not readable"'
            }
        }

stage('Set Version') {
    steps {
        script {
            env.SERVICE_VERSION = sh(script: 'mvn help:evaluate -Dexpression=project.version -q -DforceStdout', returnStdout: true).trim()
            echo "Building version: ${env.SERVICE_VERSION}"
        }
    }
}

        stage('Maven Build & Deploy to Nexus') {
            steps {
                sh 'mvn clean deploy -DskipTests'
            }
        }

        stage('SonarQube Analysis') {
            when { expression { env.SONAR_HOST_URL != null } }
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh 'mvn sonar:sonar'
                }
            }
        }

        stage('Bake Golden Image') {
            steps {
                script {
                    withEnv([
                        "SERVICE_VERSION=${env.SERVICE_VERSION}",
                        "SERVICE_NAME=${SERVICE_NAME}"
                    ]) {
                        dir('packer') {
                            sh '''
                                packer init eureka.pkr.hcl
                                packer build \
                                    -var "service_version=${SERVICE_VERSION}" \
                                    -var "service_name=${SERVICE_NAME}" \
                                    eureka.pkr.hcl
                            '''
                        }
                    }
                }
            }
        }

        stage('Record AMI ID') {
            steps {
                script {
                    dir('packer') {
                        sh '''
                            packer build -machine-readable eureka.pkr.hcl 2>&1 | tee output.txt
                            AMI_ID=$(grep -oP 'ami-[a-f0-9]+' output.txt | tail -1)
                            echo "GOLDEN_AMI_ID=$AMI_ID" > golden-ami.properties
                        '''
                        stash name: 'eureka-ami', includes: 'golden-ami.properties'
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Eureka CI & golden image built successfully."
        }
        failure {
            echo "Eureka CI failed. Check logs above."
        }
    }
}
